SESSION_SECRET="your_secure_random_string_here"
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_CALLBACK_URL="http://localhost:5173/auth/discord/callback"
IRIS_URL="http://localhost:8080"
IRIS_TIMEOUT_MS="1500"
REDIS_URI="redis://localhost:6379"
OAUTH_TOKEN_ENCRYPTION_KEY="replace_with_a_long_random_secret"
DISCORD_TOKEN="discord_bot_token"
DISCORD_API_TIMEOUT_MS="4000"

# Polarizer server-only mTLS client
POLARIZER_GRPC_ADDRESS="localhost:50051"
POLARIZER_TLS_DOMAIN="polarizer.internal"
POLARIZER_TLS_CA="/run/secrets/polarizer/ca.crt"
POLARIZER_TLS_CERT="/run/secrets/polarizer/client.crt"
POLARIZER_TLS_KEY="/run/secrets/polarizer/client.key"
POLARIZER_SERVICE_PRINCIPAL="interchat-winter"
POLARIZER_TIMEOUT_MS="2500"

TOPGG_WEBHOOK_SECRET="topgg_secret"  # you must obtain this from top.gg
DISCORD_VOTE_WEBHOOK_URL="" # the discord webhook url to send vote notifications to
